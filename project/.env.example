# 复制本文件为 .env 并填入你的配置

# ===== DeepSeek（Claude Code 代理）=====
# 从 Claude Code 或你的代理服务商获取，不是 OpenAI 官方 Key
DEEPSEEK_API_KEY=sk-你的密钥

# 代理地址（Claude Code 常用格式，末尾带 /v1）
DEEPSEEK_BASE_URL=https://llm.chudian.site/v1

# 模型名（代理支持的 DeepSeek 模型，例如 deepseek-v4-pro）
DEEPSEEK_MODEL=deepseek-v4-pro

# ===== 开发/测试 =====
# 设为 1 时使用 Mock，不调用真实 AI
MOCK_AI=0

# 数据库（固定路径，勿改除非你知道在做什么）
# DATABASE_URI=sqlite:///C:/完整路径/instance/grammar_assistant.db
