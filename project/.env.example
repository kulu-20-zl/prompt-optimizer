# 复制本文件为 .env 并填入你的配置

# ===== DeepSeek（文本润色）=====
DEEPSEEK_API_KEY=sk-你的密钥
DEEPSEEK_BASE_URL=https://llm.chudian.site/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# ===== 图片理解（Vision，与文本润色可分开配置）=====
VISION_ENABLED=1
VISION_MODEL=gpt-5.4
VISION_API_KEY=
VISION_BASE_URL=https://api.openai.com/v1
MAX_IMAGES=3
MAX_IMAGE_BYTES=4194304

# ===== 安全与运行 =====
SECRET_KEY=请改为随机长字符串
FLASK_DEBUG=1
SESSION_COOKIE_SECURE=0
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=60

# ===== 开发/测试 =====
MOCK_AI=0
MOCK_AI_DELAY=0
AI_MAX_TOKENS=1200

# ===== 数据库备份 =====
ENABLE_DB_BACKUP=1
DB_BACKUP_KEEP=5

# 数据库（固定路径，勿改除非你知道在做什么）
# DATABASE_URI=sqlite:///C:/完整路径/instance/grammar_assistant.db
